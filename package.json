{
  "name": "entities",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev",
    "safe": "bun run type-check && bun run format && bun run lint:fix && bun run lint  ",
    "build": "bun run safe && bun db:generate && bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun biome check",
    "lint:fix": "bun --bun biome check --write --unsafe",
    "test": "bun test tests/unit/api && bun test tests/unit/services && bun test tests/unit/stores && bun test tests/unit/lib",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "type-check": "bun --bun tsc --noEmit",
    "rd": "bunx -y react-doctor@latest",
    "format": "bun --bun biome format . --write",
    "pr": "bun scripts/fetch-pr-review.ts",
    "logs:deployment": "bash scripts/deployment-logs.sh",
    "m": "ollama launch claude --model minimax-m2.5:cloud",
    "g": "ollama launch claude --model glm-5:cloud",
    "postinstall": "bun db:generate",
    "db:generate": "bun prisma generate",
    "db:push": "bun prisma db push",
    "db:migrate": "bun prisma migrate dev",
    "db:studio": "bun prisma studio",
    "db:seed": "bun prisma/seed.ts",
    "db:clean": "bun prisma/seed.ts --clean"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@clerk/nextjs": "^6.38.1",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "inngest": "^3.52.3",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "posthog-js": "^1.357.1",
    "prisma": "^7.4.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@clerk/testing": "^1.14.3",
    "@playwright/test": "^1.52.0",
    "@happy-dom/global-registrator": "^20.7.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.9",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "happy-dom": "^20.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
