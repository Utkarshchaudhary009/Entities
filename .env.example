# DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=verify-full"

# Inngest Configuration
INNGEST_EVENT_KEY=your_inngest_event_key
