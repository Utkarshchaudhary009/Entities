NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
GOOGLE_GENERATIVE_AI_API_KEY="AI..."
SUPABASE_SERVICE_ROLE_KEY="guy887..."
